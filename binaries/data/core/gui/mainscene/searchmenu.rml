<rml>
    <head>
        <title></title>
        <link type="text/rcss" href="window.rcss"/>
        <style>
        body {
            display: flex;
            flex-direction: column;
            width: 50%;
            height: auto;
            position: absolute;
            right: 25%;
            top: 10%;
        }
        #results {
            display: block;
            background-color: #1a1a2e;
            border: 1px #333366;
        }
        .result_item {
            display: block;
            padding: 4px 8px;
        }
        .result_item:hover {
            background-color: #333366;
            color: yellow;
        }
        </style>
    </head>
    <body>
        <form>
            <input type="text" id="search_input" placeholder="Search..."></input>
        </form>
        <div data-model="search_results">
            <div data-if="result_list.size > 0" id="results">
            <div data-for="result : result_list">
                <a data-attr-data-entity="result.entity_id" class="result_item">{{ result.name }}</a>
            </div>
            </div>
        </div>
    </body>
</rml>
